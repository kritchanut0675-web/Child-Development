<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AI Play Coach</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Kanit:wght@300;400;600&display=swap" rel="stylesheet">
    <style>body { font-family: 'Kanit', sans-serif; background-color: #f8fafc; }</style>
</head>
<body class="p-4">
    <header class="mb-6 text-center">
        <h1 class="text-3xl font-bold text-indigo-600">⚽ AI Play Coach</h1>
        <p class="text-gray-500">กิจกรรมเพื่อพัฒนาการลูกรัก</p>
    </header>

    <div id="activity-container" class="space-y-4 max-w-md mx-auto">
        <div class="text-center py-10 text-gray-400">กำลังโหลดแผนกิจกรรม...</div>
    </div>

    <script>
        // *** สำคัญ: เอา Web App URL จาก GAS มาใส่ที่นี่ ***
        const GAS_URL = "https://script.google.com/macros/s/AKfycbzub8bcsBZiLoRb3y27oloCw-7ZxO6I7XZudAb1qeQq_Z4kLMuZ2YF3T8Ep5QmdNRuQ/exec";

        async function loadActivities() {
            try {
                // เรียกฟังก์ชัน generateDailyPlan จาก GAS
                const response = await fetch(GAS_URL + "?action=getPlan");
                const data = await response.json();
                render(data.activities);
            } catch (e) {
                document.getElementById('activity-container').innerHTML = "เกิดข้อผิดพลาดในการดึงข้อมูล";
            }
        }

        function render(activities) {
            const container = document.getElementById('activity-container');
            container.innerHTML = '';
            activities.forEach(act => {
                const card = document.createElement('div');
                card.className = "bg-white rounded-2xl p-5 shadow-sm border-l-4 border-indigo-500";
                card.innerHTML = `
                    <span class="text-xs font-bold text-indigo-500">${act.time}</span>
                    <h3 class="text-lg font-semibold text-gray-800">${act.title}</h3>
                    <p class="text-sm text-gray-600 mt-2">${act.steps}</p>
                    <div class="mt-3 text-xs bg-indigo-50 text-indigo-600 inline-block px-2 py-1 rounded-full">✨ ${act.focus}</div>
                `;
                container.appendChild(card);
            });
        }
        
        loadActivities();
    </script>
</body>
</html>
